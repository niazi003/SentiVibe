# ─────────────────────────────────────────────────────────────
# SentiVibe Backend – Environment Variables
# Copy this file to .env and fill in your real credentials.
# ─────────────────────────────────────────────────────────────

# Server
PORT=3001

# Spotify API (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret

# YouTube Data API v3 Key (https://console.cloud.google.com)
YOUTUBE_API_KEY=your_youtube_api_key

# Python AI microservice URL (LLaMA + RAG chatbot)
AI_SERVICE_URL=http://localhost:8000

# Python Emotion Detection microservice URL (text/face/voice ML)
EMOTION_SERVICE_URL=http://localhost:5001
